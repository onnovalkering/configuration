# icloud-backup secrets — DO NOT put real values in this committed file.
#
# One-time setup:
#
#   1. Generate an age key (if you don't have one):
#        mkdir -p ~/.config/sops/age
#        age-keygen -o ~/.config/sops/age/keys.txt
#        # note the "public key: age1..." line it prints
#
#   2. Copy this template somewhere private and fill in real values:
#        cp secrets.env.example /tmp/secrets.env
#        $EDITOR /tmp/secrets.env
#
#   3. Encrypt it to your age recipient (the age1... public key from step 1):
#        mkdir -p ~/.config/icloud-backup
#        age --encrypt --recipient age1XXXXXXXX \
#            --output ~/.config/icloud-backup/secrets.env.age /tmp/secrets.env
#
#   4. Shred the plaintext:
#        rm -P /tmp/secrets.env
#
# The agent decrypts ~/.config/icloud-backup/secrets.env.age at runtime with
# ~/.config/sops/age/keys.txt — no prompts, fully unattended.

RESTIC_PASSWORD=change-me
SMB_USER=change-me
SMB_PASS=change-me
